# ============ 必填项 ============

# 你的自有域名（需在 Cloudflare 设置 Catch-All 转发到下方 Gmail）
MAIL_DOMAIN=your-domain.com

# Gmail 邮箱（接收 Cloudflare 转发的验证码）
IMAP_USER=your-email@gmail.com

# Gmail 16位应用专用密码（Google 账号 → 安全 → 两步验证 → 应用专用密码）
IMAP_PASSWORD=xxxx xxxx xxxx xxxx

# 代理端口（Clash Verge 默认 7897）
PROXY_PORT=7897

# ============ 可选项 ============

# CLI Proxy API Key（Codex / Cursor 连接时填写的 Key）
CLI_PROXY_API_KEY=sk-change-me-to-your-key

# CLI Proxy 管理面板密码
CLI_PROXY_MANAGEMENT_KEY=admin123

# ============ Clash 自动 IP 轮换（可选） ============

# Clash API 端口（Clash Verge 中需启用 external-controller，默认 9090）
CLASH_API_PORT=9090

# Clash API 密钥（如 Clash 配置了 secret 则填写，否则留空）
CLASH_API_SECRET=

# 节点过滤关键词（留空 = 使用所有可用节点，排除 CN/HK）
# 示例: 填 "美国" 则只使用名称含 "美国" 的节点
CLASH_NODE_FILTER=
